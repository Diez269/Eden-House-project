</nav>

<!-- ═══════════════ PAGE ACCUEIL ═══════════════ -->
<div id="page-accueil" class="page active">
  <section class="hero" style="position:relative"><div class="img-hero-bg" style="background-image:url('data:image/jpeg;base64,')"></div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
      <p class="eyebrow">Ngazidja · Comores · Océan Indien</p>
      <h1>Le sanctuaire<br><em>qui vous redonne</em><br>votre liberté</h1>
      <p class="hero-tagline">Premier éco-sanctuaire de déconnexion douce de l'océan Indien. Pas besoin d'éteindre votre téléphone — nous vous donnons une raison plus belle de le laisser en poche.</p>
      <div class="hero-btns">
        <a class="btn-primary" href="#" onclick="showPage('offres')">Découvrir nos forfaits</a>
        <a class="btn-ghost" href="#" onclick="showPage('seminaire')">Séminaires d'entreprise</a>
      </div>
    </div>
    <div class="hero-stats">
      <div class="stat"><span class="stat-val">✦</span><span class="stat-lbl">Éco-bungalows exclusifs</span></div>
      <div class="stat"><span class="stat-val">350€</span><span class="stat-lbl">/ nuit tout compris</span></div>
      <div class="stat"><span class="stat-val">2027</span><span class="stat-lbl">Ouverture</span></div>
      <div class="stat"><span class="stat-val">🏆</span><span class="stat-lbl">Green Key visée</span></div>
    </div>
  </section>

  <div class="usp-bar">
    <span>🌿 80% approvisionnement local</span><span class="sep">·</span>
    <span>📵 Détox numérique douce</span><span class="sep">·</span>
    <span>🏝 Réserve UNESCO</span><span class="sep">·</span>
    <span>⚡ Énergie solaire</span><span class="sep">·</span>
    <span>🤿 Plongée responsable</span>
  </div>

  <section class="section" style="background:#fff">
    <div class="container">
      <p class="label">Le concept</p>
      <h2 style="text-align:center">Un sanctuaire en <em>trois temps</em></h2>
      <p class="intro-text" style="text-align:center;max-width:600px;margin:0 auto 0">Eden House structure votre séjour autour de trois phases qui permettent une régénération profonde.</p>
      <div class="pillars-grid">
        <div class="pillar pillar--dark reveal">
          <span class="pillar-num">01</span><span class="pillar-icon">📵</span>
          <h3>Déconnexion numérique</h3><p class="pillar-sub">Lâcher Prise</p>
          <ul><li>Consigne des appareils</li><li>Chambres sans TV</li><li>Wi-Fi discret & volontaire</li><li>Aucune pression</li></ul>
        </div>
        <div class="pillar pillar--mid reveal">
          <span class="pillar-num">02</span><span class="pillar-icon">🌿</span>
          <h3>Reconnexion à la nature</h3><p class="pillar-sub">Immersion</p>
          <ul><li>Bains de forêt</li><li>Observation tortues & dauphins</li><li>Plongée responsable</li><li>Randonnées volcan</li></ul>
        </div>
        <div class="pillar pillar--sage reveal">
          <span class="pillar-num">03</span><span class="pillar-icon">🧘</span>
          <h3>Reconnexion à soi</h3><p class="pillar-sub">L'Essentiel</p>
          <ul><li>Yoga & méditation</li><li>Spa aux huiles locales</li><li>Cuisine saine & locale</li><li>Ateliers bien-être</li></ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--sand)">
    <div class="container">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:center">
        <div>
          <p class="label">Nos forfaits</p>
          <h2>Trois expériences,<br><em>un seul cadre</em></h2>
          <p class="intro-text">Chaque forfait est tout compris pour 2 personnes : hébergement, repas, activités. Prix moyen : <strong>350 €/nuit</strong>.</p>
          <a class="btn-primary" href="#" onclick="showPage('offres')" style="margin-top:2rem;display:inline-block">Voir tous les forfaits →</a>
        </div>
        <div style="display:flex;flex-direction:column;gap:1rem">
          <div class="reveal" style="display:flex;align-items:center;justify-content:space-between;padding:1.25rem 1.5rem;background:#fff;border-left:4px solid var(--sage)">
            <span style="font-size:0.9rem;font-weight:500">🌊 Découverte</span>
            <span style="font-family:'Cormorant Garamond',serif;font-size:1.6rem;color:var(--forest)">1 050 €</span>
            <span style="font-size:0.72rem;color:var(--gray)">3 nuits</span>
          </div>
          <div class="reveal" style="display:flex;align-items:center;justify-content:space-between;padding:1.25rem 1.5rem;background:var(--forest);border-left:4px solid var(--sage);position:relative">
            <span style="position:absolute;top:-10px;left:1rem;background:var(--ocre);color:#fff;font-size:0.6rem;font-weight:600;padding:0.2rem 0.6rem;letter-spacing:0.1em">★ RECOMMANDÉ</span>
            <span style="font-size:0.9rem;font-weight:500;color:#fff">🌿 Ressourcement</span>
            <span style="font-family:'Cormorant Garamond',serif;font-size:1.6rem;color:var(--sage)">1 650 €</span>
            <span style="font-size:0.72rem;color:rgba(255,255,255,0.5)">5 nuits</span>
          </div>
          <div class="reveal" style="display:flex;align-items:center;justify-content:space-between;padding:1.25rem 1.5rem;background:#fff;border-left:4px solid var(--sage)">
            <span style="font-size:0.9rem;font-weight:500">✨ Transformation</span>
            <span style="font-family:'Cormorant Garamond',serif;font-size:1.6rem;color:var(--forest)">2 450 €</span>
            <span style="font-size:0.72rem;color:var(--gray)">7 nuits</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  
  <section class="section" style="background:#fff">
    <div style="max-width:1100px;margin:0 auto">
      <div class="photo-split">
        <div>
          <img src="data:image/jpeg;base64," alt="Carte des Comores — localisation Eden House" class="carte-img">
          <p class="img-caption">Grande Comore (Ngazidja) — Mitsamihouli, au nord de l'île</p>
        </div>
        <div>
          <p style="color:var(--sage);font-size:.75rem;letter-spacing:2px;text-transform:uppercase;margin-bottom:.5rem">
            <img src="data:image/jpeg;base64," class="flag-sm" alt="Drapeau Comores" style="width:44px;height:30px;border-radius:4px;margin-right:8px">Pourquoi les Comores
          </p>
          <h2 style="font-family:'Cormorant Garamond',serif;font-size:2.2rem;font-weight:300;margin-bottom:1rem">
            Au cœur de l'<em style="color:var(--sage)">océan Indien</em>
          </h2>
          <p style="color:#555;line-height:1.8;margin-bottom:1.5rem">Mitsamihouli est l'un des joyaux préservés de Grande Comore — plages vierges, forêts primaires, volcan Karthala et réserve de biosphère UNESCO. C'est ici qu'Eden House prendra vie en 2030.</p>
          <ul style="list-style:none;display:flex;flex-direction:column;gap:.75rem">
            <li style="display:flex;align-items:center;gap:1rem;padding:.75rem 1rem;background:var(--lgray);border-left:3px solid var(--sage)"><span style="font-size:1.2rem">🌋</span><div><strong style="display:block;font-size:.88rem;color:var(--forest)">Volcan Karthala (2 361 m)</strong><small style="color:#888;font-size:.78rem">Randonnée signature — panorama sur l'océan</small></div></li>
            <li style="display:flex;align-items:center;gap:1rem;padding:.75rem 1rem;background:var(--lgray);border-left:3px solid var(--sage)"><span style="font-size:1.2rem">🐬</span><div><strong style="display:block;font-size:.88rem;color:var(--forest)">Dauphins & Tortues</strong><small style="color:#888;font-size:.78rem">Observation en mer au lever du soleil</small></div></li>
            <li style="display:flex;align-items:center;gap:1rem;padding:.75rem 1rem;background:var(--lgray);border-left:3px solid var(--sage)"><span style="font-size:1.2rem">🏆</span><div><strong style="display:block;font-size:.88rem;color:var(--forest)">Jeux des Îles OI 2027</strong><small style="color:#888;font-size:.78rem">Visibilité internationale au moment de notre ouverture</small></div></li>
            <li style="display:flex;align-items:center;gap:1rem;padding:.75rem 1rem;background:var(--lgray);border-left:3px solid var(--sage)"><span style="font-size:1.2rem">🌿</span><div><strong style="display:block;font-size:.88rem;color:var(--forest)">Réserve UNESCO</strong><small style="color:#888;font-size:.78rem">Cadre naturel protégé, biodiversité exceptionnelle</small></div></li>
          </ul>
        </div>
      </div>
    </div>
  </section>
<section class="section eco-section">
    <div class="container">
      <p class="label" style="color:var(--sage)">Éco-responsabilité</p>
      <h2>Construire <em>sans dénaturer</em></h2>
      <div class="eco-grid">
        <div class="eco-card reveal"><span>⚡</span><strong>Énergie solaire</strong><p>Panneaux solaires, éoliennes, autonomie partielle</p></div>
        <div class="eco-card reveal"><span>💧</span><strong>Eau naturelle</strong><p>Récupération de pluie, traitement, irrigation potager</p></div>
        <div class="eco-card reveal"><span>♻️</span><strong>Zéro déchet</strong><p>Zéro plastique, compostage, recyclage systématique</p></div>
        <div class="eco-card reveal"><span>🪵</span><strong>Construction locale</strong><p>Bois, pierre, aloès des Comores · Ventilation naturelle</p></div>
      </div>
      <div class="eco-bottom">
        <div class="eco-stat reveal"><span class="big">80%</span><span>Approvisionnement local</span></div>
        <div class="eco-stat reveal"><span class="big">🏆</span><span>Green Key visée dès l'an 1</span></div>
        <div class="eco-stat reveal"><span class="big">UNESCO</span><span>Réserve de biosphère · Ngazidja</span></div>
      </div>
    </div>
  </section>

  <section class="section" style="background:var(--sand)">
    <div class="container">
      <div class="cta-box reveal">
        <div>
          <p class="label" style="color:var(--sage)">Offre B2B</p>
          <h2>Organisez votre <em>séminaire</em> autrement</h2>
          <p>Salle 30 personnes, cadre exceptionnel, dès 95 €/pers. La seule offre éco-responsable des Comores.</p>
        </div>
        <a class="btn-primary" href="#" onclick="showPage('seminaire')">Découvrir l'offre séminaire →</a>
      </div>
    </div>
  </section>

  <footer class="footer">
    <div class="footer-inner">
      <div><p class="footer-logo">Eden <em>House</em></p><p class="footer-sub">Green & Détox Numérique<br>6 Rue du Badamier, Mitsamihouli<br>Ngazidja — Comores</p></div>
      <div><p class="footer-h">Navigation</p><ul class="footer-links"><li><a onclick="showPage('accueil')">Accueil</a></li><li><a onclick="showPage('offres')">Offres & Forfaits</a></li><li><a onclick="showPage('seminaire')">Séminaires</a></li><li><a onclick="showPage('contact')">Contact</a></li></ul></div>
      <div><p class="footer-h">Engagement</p><ul class="footer-links"><li>🏆 Green Key</li><li>🌿 80% local</li><li>⚡ Solaire</li><li>🏝 UNESCO</li></ul></div>
    </div>
    <div class="footer-bottom"><span>© 2026 Eden House · Projet Bachelor · Imrane Mohamed Abdou</span><span>Ouverture 2030</span></div>
  </footer>
</div>

<!-- ═══════════════ PAGE OFFRES ═══════════════ -->
<div id="page-offres" class="page">
  <div class="page-hero">
    <p class="label" style="justify-content:center">Nos forfaits</p>
    <h1>Offres & <em>Expériences</em></h1>
    <p>Chaque séjour inclut hébergement, repas, activités. Tout compris. Aucune surprise.</p>
  </div>

  <section class="section">
    <div class="container">
      <p class="label">Forfaits séjour</p>
      <h2>Trois durées,<br><em>une transformation</em></h2>
      <p class="intro-text" style="margin-bottom:2rem">Prix moyen par nuit : 350 € tout compris pour 2 personnes. Ouverture prévue en 2030.</p>
      <div class="packages">
        <div class="package reveal">
          <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1rem"><span style="font-size:2rem">🌊</span><div><p class="pkg-name">Découverte</p><p class="pkg-dur">3 nuits / 4 jours</p></div></div>
          <p class="pkg-price"><span>€</span>1 050</p>
          <p class="pkg-unit">pour 2 personnes · tout compris</p>
          <ul class="pkg-list"><li>Hébergement en éco-bungalow</li><li>Tous les repas à La Table des Sens</li><li>2 activités au choix</li><li>Accès spa & piscine naturelle</li><li>Yoga & méditation</li></ul>
          <a href="#" onclick="showPage('contact')" class="btn-outline full-w">Réserver</a>
        </div>
        <div class="package package--featured reveal">
          <div class="pkg-badge">★ Le plus populaire</div>
          <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1rem"><span style="font-size:2rem">🌿</span><div><p class="pkg-name">Ressourcement</p><p class="pkg-dur">5 nuits / 6 jours</p></div></div>
          <p class="pkg-price"><span>€</span>1 650</p>
          <p class="pkg-unit">pour 2 personnes · tout compris</p>
          <ul class="pkg-list"><li>Hébergement éco-bungalow premium</li><li>Tous les repas & snacks locaux</li><li>3 activités au choix</li><li>Séance spa individuelle incluse</li><li>Yoga & méditation quotidiens</li><li>Observation tortues & dauphins</li></ul>
          <a href="#" onclick="showPage('contact')" class="btn-primary full-w">Réserver</a>
        </div>
        <div class="package reveal">
          <div style="display:flex;align-items:center;gap:1rem;margin-bottom:1rem"><span style="font-size:2rem">✨</span><div><p class="pkg-name">Transformation</p><p class="pkg-dur">7 nuits / 8 jours</p></div></div>
          <p class="pkg-price"><span>€</span>2 450</p>
          <p class="pkg-unit">pour 2 personnes · tout compris</p>
          <ul class="pkg-list"><li>Éco-bungalow vue mer</li><li>Tous les repas & boissons inclus</li><li>Programme bien-être complet</li><li>Spa illimité & activités</li><li>Plongée responsable guidée</li><li>Randonnée volcan Karthala</li></ul>
          <a href="#" onclick="showPage('contact')" class="btn-outline full-w">Réserver</a>
        </div>
      </div>
      <p class="price-note">Prix HT · TVA locale à appliquer · Ouverture 2030 · Acompte 30% à la réservation</p>
    </div>
  </section>

  <section class="section" style="background:var(--sand)">
    <div class="container">
      <div class="two-col">
        <div>
          <p class="label">L'hébergement</p>
          <h2>Éco-bungalows <em>& Espace bien-être</em></h2>
          
          <ul class="features-list">
            <li><span>🪵</span> Matériaux 100% locaux (bois, pierre, aloès)</li>
            <li><span>🌱</span> Intégration végétale complète</li>
            <li><span>💧</span> Piscine naturelle sans chlore</li>
            <li><span>🎨</span> Design épuré & bioclimatique</li>
            <li><span>❌</span> Pas de TV ni de minibar digital</li>
            <li><span>✅</span> Mobilier artisanal local</li>
          </ul>
        </div>
        <div class="resto-box">
          <p class="label" style="color:var(--sage)">Restaurant</p>
          <h3 style="color:#fff;font-family:'Cormorant Garamond',serif;font-size:1.8rem;margin-bottom:1rem">La Table des Sens</h3>
          <p style="color:rgba(255,255,255,0.7);font-style:italic;margin-bottom:1.5rem">Farm-to-table & Sea-to-table</p>
          <ul style="list-style:none;color:rgba(255,255,255,0.85);line-height:2.2;font-size:0.9rem">
            <li>🌱 Potager biologique sur place</li>
            <li>🐟 Pêche responsable, saison locale</li>
            <li>♻️ Zéro déchet & compostage</li>
            <li>📵 Ardoise artisanale — sans écran</li>
            <li>🏠 80% d'approvisionnement local</li>
            <li>💰 Inclus dans tous les forfaits</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <p class="label">Activités</p>
