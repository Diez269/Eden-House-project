    <h1>Le Bar <em>Eden</em></h1>
    <p>Face au coucher de soleil · Infusions bio · Mocktails signatures · Spiritueux premium · 10h–23h</p>
  </div>

  <section class="menu-section">
    <div style="max-width:1100px;margin:0 auto">

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:3rem;align-items:start" class="two-col-responsive">

        <div>
          
        <div class="img-duo" style="margin-bottom:2rem">
