<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Eden House — Green & Détox Numérique · Comores</title>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{--forest:#1B5E38;--forest2:#14482A;--mid:#2E7D52;--sage:#4CAF6F;--lagon:#1A6B8A;--ocre:#C87D3A;--sand:#F5EEE0;--cream:#FDFAF4;--dark:#0F1F17;--dark2:#1A1A1A;--gray:#666;--lgray:#F2F2F2;--white:#fff}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--cream);color:var(--dark2)}
/* NAV */
.nav{position:fixed;top:0;left:0;right:0;z-index:1000;display:flex;align-items:center;justify-content:space-between;padding:1rem 3rem;background:rgba(15,31,23,0.97);backdrop-filter:blur(12px);border-bottom:1px solid rgba(76,175,111,0.15)}
.nav-logo{font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-weight:300;color:#fff;text-decoration:none}
.nav-logo em{color:var(--sage)}
.nav-links{display:flex;list-style:none;gap:0}
.nav-links a{text-decoration:none;color:rgba(255,255,255,0.7);font-size:0.82rem;font-weight:500;padding:0.5rem 1rem;transition:color 0.2s;border-bottom:2px solid transparent}
.nav-links a:hover,.nav-links a.active{color:var(--sage);border-bottom-color:var(--sage)}
.nav-burger{display:none;background:none;border:none;color:#fff;font-size:1.4rem;cursor:pointer}
/* PAGES */
.page{display:none;padding-top:64px;min-height:100vh}
.page.active{display:block}
/* HERO */
.hero{min-height:100vh;background:linear-gradient(160deg,var(--forest2) 0%,var(--forest) 50%,#0d2a1e 100%);position:relative;overflow:hidden;display:flex;flex-direction:column;justify-content:center;padding:8rem 3rem 3rem}
.hero-overlay{position:absolute;inset:0;background:repeating-linear-gradient(-45deg,transparent,transparent 80px,rgba(255,255,255,0.015) 80px,rgba(255,255,255,0.015) 82px);pointer-events:none}
.hero-content{position:relative;z-index:2;max-width:680px}
.eyebrow{font-size:0.7rem;font-weight:500;letter-spacing:0.3em;text-transform:uppercase;color:var(--sage);margin-bottom:1.5rem;display:flex;align-items:center;gap:0.75rem}
.eyebrow::before{content:'';width:2rem;height:1px;background:var(--sage)}
.hero h1{font-family:'Cormorant Garamond',serif;font-size:clamp(3rem,6vw,5.5rem);font-weight:300;color:#fff;line-height:1.05;margin-bottom:1.5rem}
.hero h1 em{color:var(--sage);display:block}
.hero-tagline{font-size:1rem;color:rgba(255,255,255,0.65);line-height:1.8;max-width:520px;margin-bottom:2.5rem}
.hero-btns{display:flex;gap:1rem;flex-wrap:wrap}
.hero-stats{display:flex;gap:0;margin-top:4rem;border-top:1px solid rgba(76,175,111,0.2);padding-top:2rem;flex-wrap:wrap;position:relative;z-index:2}
.stat{flex:1;min-width:110px;text-align:center;padding:1rem}
.stat-val{font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:300;color:var(--sage);display:block}
.stat-lbl{font-size:0.7rem;color:rgba(255,255,255,0.5);letter-spacing:0.08em}
/* USP BAR */
.usp-bar{background:var(--dark2);padding:1rem 3rem;display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap;justify-content:center;font-size:0.78rem;color:rgba(255,255,255,0.65)}
.usp-bar .sep{color:rgba(76,175,111,0.4)}
/* SECTIONS */
.section{padding:6rem 3rem}
.container{max-width:1140px;margin:0 auto}
.label{font-size:0.65rem;font-weight:600;letter-spacing:0.3em;text-transform:uppercase;color:var(--sage);margin-bottom:0.75rem;display:flex;align-items:center;gap:0.6rem}
.label::before{content:'';width:1.5rem;height:1px;background:var(--sage)}
h2{font-family:'Cormorant Garamond',serif;font-size:clamp(2rem,3.5vw,3rem);font-weight:300;color:var(--forest);margin-bottom:1rem}
h2 em{color:var(--ocre)}
.intro-text{font-size:0.95rem;line-height:1.9;color:var(--gray)}
/* BUTTONS */
.btn-primary{display:inline-block;background:var(--sage);color:var(--dark);padding:0.85rem 2rem;font-size:0.8rem;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;text-decoration:none;transition:all 0.25s;border:none;cursor:pointer}
.btn-primary:hover{background:#5DC87E;transform:translateY(-2px)}
.btn-ghost{display:inline-block;border:1px solid rgba(255,255,255,0.35);color:#fff;padding:0.85rem 2rem;font-size:0.8rem;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;text-decoration:none;transition:all 0.25s;cursor:pointer}
.btn-ghost:hover{border-color:#fff;background:rgba(255,255,255,0.05)}
.btn-outline{display:inline-block;border:1px solid var(--forest);color:var(--forest);padding:0.85rem 2rem;font-size:0.8rem;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;text-decoration:none;transition:all 0.25s;background:transparent;cursor:pointer}
.btn-outline:hover{background:var(--forest);color:#fff}
/* PILLARS */
.pillars-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:0;margin-top:4rem}
.pillar{padding:3rem 2.5rem;position:relative;overflow:hidden;transition:filter 0.3s}
.pillar:hover{filter:brightness(1.08)}
.pillar--dark{background:var(--forest)}
.pillar--mid{background:var(--mid)}
.pillar--sage{background:var(--sage)}
.pillar-icon{font-size:2.5rem;display:block;margin-bottom:1.5rem}
.pillar-num{position:absolute;top:1rem;right:1.5rem;font-family:'Cormorant Garamond',serif;font-size:5rem;font-weight:300;color:rgba(255,255,255,0.07);line-height:1}
.pillar h3{font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:400;color:#fff;margin-bottom:0.25rem}
.pillar-sub{font-size:0.7rem;letter-spacing:0.15em;text-transform:uppercase;color:rgba(255,255,255,0.55);margin-bottom:1.5rem}
.pillar ul{list-style:none}
.pillar ul li{font-size:0.85rem;color:rgba(255,255,255,0.85);padding:0.45rem 0;border-bottom:1px solid rgba(255,255,255,0.1);display:flex;align-items:flex-start;gap:0.6rem}
.pillar ul li::before{content:'→';color:rgba(255,255,255,0.4);font-size:0.75rem;flex-shrink:0;margin-top:2px}
.pillar ul li:last-child{border-bottom:none}
/* PACKAGES */
.packages{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:3rem}
.package{background:#fff;padding:2.5rem;position:relative;transition:transform 0.3s,box-shadow 0.3s;border-top:3px solid var(--lgray)}
.package:hover{transform:translateY(-6px);box-shadow:0 20px 60px rgba(27,94,56,0.12);border-top-color:var(--sage)}
.package--featured{background:var(--forest);border-top-color:var(--sage)}
.pkg-badge{position:absolute;top:-12px;left:2rem;background:var(--ocre);color:#fff;font-size:0.6rem;font-weight:600;letter-spacing:0.1em;text-transform:uppercase;padding:0.3rem 0.8rem}
.pkg-name{font-size:0.65rem;font-weight:600;letter-spacing:0.2em;text-transform:uppercase;color:var(--sage);margin-bottom:0.5rem}
.pkg-price{font-family:'Cormorant Garamond',serif;font-size:3rem;font-weight:300;color:var(--forest);line-height:1;margin:0.75rem 0 0.25rem}
.pkg-price span{font-size:1.2rem;vertical-align:super}
.package--featured .pkg-price{color:#fff}
.pkg-dur{font-family:'Cormorant Garamond',serif;font-size:1.1rem;color:inherit;margin-bottom:0.25rem}
.package--featured .pkg-dur{color:#fff}
.pkg-unit{font-size:0.75rem;color:var(--gray);margin-bottom:1.5rem}
.package--featured .pkg-unit{color:rgba(255,255,255,0.5)}
.pkg-list{list-style:none;margin-bottom:1.5rem}
.pkg-list li{font-size:0.83rem;padding:0.4rem 0;border-bottom:1px solid rgba(0,0,0,0.06);display:flex;align-items:flex-start;gap:0.6rem}
.package--featured .pkg-list li{border-color:rgba(255,255,255,0.1);color:rgba(255,255,255,0.85)}
.pkg-list li::before{content:'✓';color:var(--sage);flex-shrink:0;font-size:0.7rem;margin-top:2px}
.pkg-list li:last-child{border-bottom:none}
.full-w{width:100%;text-align:center;margin-top:1rem}
/* TARIFS SÉMINAIRE */
.tarif-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1.5rem;margin-top:2rem}
.tarif-card{padding:2rem;background:#fff;border-top:3px solid var(--sage);transition:box-shadow 0.3s}
.tarif-card:hover{box-shadow:0 12px 40px rgba(27,94,56,0.1)}
.tarif-card--dark{background:var(--forest);border-top-color:var(--sage)}
.tarif-icon{font-size:2rem;display:block;margin-bottom:0.75rem}
.tarif-card h3{font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:400;color:var(--forest);margin-bottom:1.2rem}
.tarif-card--dark h3{color:#fff}
.tarif-rows{display:flex;flex-direction:column;gap:0.4rem}
.tarif-row{display:flex;justify-content:space-between;align-items:center;padding:0.65rem 0.9rem;background:var(--lgray);font-size:0.88rem}
.tarif-row:nth-child(2n){background:#fff;border:1px solid #eee}
.tarif-row--dark{background:rgba(255,255,255,0.08);color:#fff;border:none}
.tarif-row--dark2{background:rgba(255,255,255,0.14);color:#fff;border:none}
.tarif-row span{color:var(--gray)}
.tarif-row--dark span,.tarif-row--dark2 span{color:rgba(255,255,255,0.6)}
.tarif-row strong{color:var(--forest);font-family:'Cormorant Garamond',serif;font-size:1.2rem}
.tarif-row--dark strong,.tarif-row--dark2 strong{color:var(--sage)}
.tarif-note{font-size:0.78rem;color:var(--gray);margin-top:0.9rem;font-style:italic}
.tarif-note-global{display:flex;align-items:flex-start;gap:1rem;background:var(--forest);padding:1.5rem 2rem;margin-top:2rem;color:#fff}
.tarif-note-global span{font-size:1.5rem;flex-shrink:0}
.tarif-note-global p{font-size:0.88rem;color:rgba(255,255,255,0.8);line-height:1.7}
.tarif-note-global strong{color:var(--sage)}
/* ECO */
.eco-section{background:var(--forest2)}
.eco-section h2{color:#fff}
.eco-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin:3rem 0}
.eco-card{padding:1.75rem;background:rgba(255,255,255,0.05);border:1px solid rgba(76,175,111,0.2);transition:border-color 0.3s}
.eco-card:hover{border-color:var(--sage)}
.eco-card span{font-size:2rem;display:block;margin-bottom:1rem}
.eco-card strong{display:block;color:var(--sage);font-size:0.9rem;margin-bottom:0.5rem}
.eco-card p{font-size:0.8rem;color:rgba(255,255,255,0.6);line-height:1.6}
.eco-bottom{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem}
.eco-stat{text-align:center;padding:1.5rem;background:rgba(255,255,255,0.04);border-top:2px solid var(--sage)}
.eco-stat .big{display:block;font-family:'Cormorant Garamond',serif;font-size:2.5rem;color:var(--sage)}
.eco-stat span:last-child{font-size:0.8rem;color:rgba(255,255,255,0.5)}
/* ACTIVITÉS */
.activities{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:2rem}
.activity{padding:2rem;background:#fff;border-bottom:3px solid transparent;transition:all 0.3s}
.activity:hover{border-bottom-color:var(--sage);transform:translateY(-4px);box-shadow:0 12px 40px rgba(27,94,56,0.1)}
.activity span{font-size:2rem;display:block;margin-bottom:1rem}
.activity strong{display:block;font-size:1rem;color:var(--forest);margin-bottom:0.5rem}
.activity p{font-size:0.82rem;color:var(--gray);line-height:1.6}
/* CONTACT */
.contact-grid{display:grid;grid-template-columns:1.4fr 1fr;gap:4rem}
.contact-form{display:flex;flex-direction:column;gap:1.25rem}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:1rem}
.form-group{display:flex;flex-direction:column;gap:0.4rem}
.form-group label{font-size:0.72rem;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--gray)}
.form-group input,.form-group select,.form-group textarea{padding:0.85rem 1rem;border:1px solid #ddd;font-family:'DM Sans',sans-serif;font-size:0.9rem;color:var(--dark2);outline:none;transition:border-color 0.2s}
.form-group input:focus,.form-group select:focus,.form-group textarea:focus{border-color:var(--sage)}
.form-group textarea{resize:vertical}
.form-note{font-size:0.72rem;color:var(--gray);text-align:center;font-style:italic}
.form-success{display:none;flex-direction:column;align-items:center;text-align:center;padding:4rem 2rem;gap:1rem}
.form-success span{font-size:3rem}
.form-success h3{font-family:'Cormorant Garamond',serif;font-size:2rem;color:var(--forest)}
.info-cards{display:flex;flex-direction:column;gap:1.5rem}
.info-card{background:#fff;padding:2rem;border-top:3px solid var(--sage)}
.info-card h3{font-family:'Cormorant Garamond',serif;font-size:1.3rem;color:var(--forest);margin-bottom:1.25rem}
.info-row{display:flex;align-items:flex-start;gap:1rem;margin-bottom:1rem;font-size:0.85rem}
.info-row span{font-size:1.2rem;flex-shrink:0}
.info-row strong{display:block;font-size:0.78rem;text-transform:uppercase;letter-spacing:0.08em;color:var(--gray);margin-bottom:0.2rem}
/* FAQ */
.faq-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:1.5rem;margin-top:2rem}
.faq{padding:2rem;background:#fff;border-left:3px solid var(--sage)}
.faq h4{font-size:0.95rem;color:var(--forest);margin-bottom:0.75rem;font-weight:600}
.faq p{font-size:0.84rem;color:var(--gray);line-height:1.7}
/* FEATURES LIST */
.features-list{list-style:none;display:flex;flex-direction:column;gap:0.75rem}
.features-list li{display:flex;align-items:center;gap:1rem;font-size:0.88rem;padding:0.75rem 1rem;background:#fff;border-left:3px solid var(--sage)}
.features-list li span{font-size:1.2rem;flex-shrink:0}
/* CTA BOX */
.cta-box{background:var(--forest);padding:3.5rem;display:flex;align-items:center;justify-content:space-between;gap:3rem;flex-wrap:wrap;margin-top:4rem}
.cta-box h2{color:#fff}
.cta-box h2 em{color:var(--sage)}
.cta-box p{color:rgba(255,255,255,0.65);font-size:0.9rem;margin-top:0.75rem}
/* FOOTER */
.footer{background:var(--dark);color:#fff;padding:4rem 3rem 0}
.footer-inner{max-width:1140px;margin:0 auto;display:grid;grid-template-columns:1.5fr 1fr 1fr;gap:3rem;padding-bottom:3rem}
.footer-logo{font-family:'Cormorant Garamond',serif;font-size:1.8rem;font-weight:300;margin-bottom:0.75rem}
.footer-logo em{color:var(--sage)}
.footer-sub{font-size:0.8rem;color:rgba(255,255,255,0.4);line-height:1.9}
.footer-h{font-size:0.65rem;font-weight:600;letter-spacing:0.2em;text-transform:uppercase;color:var(--sage);margin-bottom:1rem}
.footer-links{list-style:none;font-size:0.82rem;color:rgba(255,255,255,0.5);line-height:2.2}
.footer-links a{color:rgba(255,255,255,0.5);text-decoration:none;cursor:pointer}
.footer-links a:hover{color:var(--sage)}
.footer-bottom{border-top:1px solid rgba(255,255,255,0.08);padding:1.5rem 3rem;display:flex;justify-content:space-between;font-size:0.72rem;color:rgba(255,255,255,0.25);flex-wrap:wrap;gap:0.5rem;max-width:100%}
/* PAGE HERO */
.page-hero{background:linear-gradient(135deg,var(--forest2),var(--forest));padding:8rem 3rem 5rem;text-align:center;border-bottom:3px solid var(--sage)}
.page-hero h1{font-family:'Cormorant Garamond',serif;font-size:clamp(2.5rem,5vw,4.5rem);font-weight:300;color:#fff;margin:0.5rem 0 1rem}
.page-hero h1 em{color:var(--sage)}
.page-hero p{color:rgba(255,255,255,0.65);font-size:1rem;max-width:600px;margin:0 auto}
/* RESTO BOX */
.resto-box{background:var(--forest);padding:2.5rem;border-top:4px solid var(--sage)}
/* AVANTAGES SÉMINAIRE */
.avantages{display:flex;flex-direction:column;gap:1rem;margin-top:1.5rem}
.avantage{display:flex;gap:1rem;align-items:flex-start;padding:1rem;background:var(--lgray)}
.av-num{font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:300;color:rgba(27,94,56,0.2);line-height:1;flex-shrink:0}
.avantage strong{display:block;font-size:0.9rem;color:var(--forest);margin-bottom:0.25rem}
.avantage p{font-size:0.82rem;color:var(--gray);line-height:1.5}
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:start;margin-top:3rem}
.price-note{text-align:center;font-size:0.78rem;color:var(--gray);font-style:italic;margin-top:1.5rem;line-height:1.8}
/* REVEAL */
.reveal{opacity:0;transform:translateY(30px);transition:opacity 0.7s ease,transform 0.7s ease}
.reveal.visible{opacity:1;transform:translateY(0)}
/* MOBILE */
@media(max-width:900px){
  .nav{padding:1rem 1.5rem}
  .nav-links{display:none;flex-direction:column;position:absolute;top:100%;left:0;right:0;background:var(--dark2);padding:1.5rem;gap:1rem}
  .nav.open .nav-links{display:flex}
  .nav-burger{display:block}
  .hero{padding:7rem 1.5rem 3rem}
  .section{padding:4rem 1.5rem}
  .pillars-grid,.packages{grid-template-columns:1fr}
  .eco-grid{grid-template-columns:1fr 1fr}
  .eco-bottom,.activities{grid-template-columns:1fr}
  .tarif-grid,.two-col,.contact-grid,.faq-grid{grid-template-columns:1fr}
  .footer-inner{grid-template-columns:1fr;gap:2rem}
  .footer-bottom{flex-direction:column;padding:1.5rem}
  .cta-box{flex-direction:column;text-align:center}
  .usp-bar{padding:1rem;gap:0.75rem;font-size:0.72rem}
}

/* ── Nouvelles pages ── */
.menu-section{padding:5rem 3rem;background:#fff}
.menu-section:nth-child(even){background:var(--sand)}
.menu-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:2rem;margin-top:3rem}
.menu-card{background:var(--forest2);border-radius:16px;overflow:hidden;border:1px solid rgba(76,175,111,0.2)}
.menu-card-header{background:var(--forest);padding:1.5rem 2rem;display:flex;align-items:center;gap:1rem}
.menu-card-header .icon{font-size:2rem}
.menu-card-header h3{color:var(--sage);font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:400;margin:0}
.menu-card-header p{color:rgba(255,255,255,0.5);font-size:0.78rem;margin:0.2rem 0 0}
.menu-card-body{padding:1.5rem 2rem}
.menu-item{display:flex;justify-content:space-between;align-items:baseline;padding:0.6rem 0;border-bottom:1px solid rgba(255,255,255,0.06)}
.menu-item:last-child{border-bottom:none}
.menu-item-name{color:#fff;font-size:0.9rem;font-weight:500}
.menu-item-desc{color:rgba(255,255,255,0.5);font-size:0.78rem;margin-top:2px}
.menu-item-tag{background:rgba(76,175,111,0.15);color:var(--sage);font-size:0.7rem;padding:2px 8px;border-radius:20px;white-space:nowrap;margin-left:1rem}
.menu-note{background:rgba(76,175,111,0.08);border-left:3px solid var(--sage);padding:1rem 1.5rem;border-radius:0 8px 8px 0;margin-top:2rem}
.menu-note p{color:var(--dark2);font-size:0.85rem;margin:0;line-height:1.6}
.tarif-badge{display:inline-block;background:var(--gold,#C8960A);color:#0F1F17;font-size:0.75rem;font-weight:600;padding:3px 10px;border-radius:20px;margin-left:8px}
.spa-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(260px,1fr));gap:1.5rem;margin-top:2.5rem}
.spa-card{background:var(--forest2);border-radius:16px;padding:2rem;border:1px solid rgba(76,175,111,0.15);text-align:center;transition:transform 0.2s}
.spa-card:hover{transform:translateY(-4px)}
.spa-card .spa-icon{font-size:2.8rem;margin-bottom:1rem}
.spa-card h3{color:var(--sage);font-family:'Cormorant Garamond',serif;font-size:1.3rem;font-weight:400;margin:0 0 0.5rem}
.spa-card p{color:rgba(255,255,255,0.6);font-size:0.85rem;line-height:1.6;margin:0}
.spa-card .dur{color:rgba(255,255,255,0.35);font-size:0.75rem;margin-top:0.8rem}
.horaire-band{background:var(--forest);border-radius:12px;padding:1.2rem 2rem;display:flex;flex-wrap:wrap;gap:2rem;justify-content:center;margin-top:2.5rem}
.horaire-item{text-align:center}
.horaire-item .h-label{color:rgba(255,255,255,0.45);font-size:0.72rem;letter-spacing:1px;text-transform:uppercase}
.horaire-item .h-time{color:var(--sage);font-size:1rem;font-weight:500;margin-top:2px}
.bar-cocktails{display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:1.2rem;margin-top:2.5rem}
.cocktail-card{background:var(--forest2);border-radius:12px;padding:1.5rem;border-left:3px solid var(--sage)}
.cocktail-card h4{color:#fff;font-size:0.95rem;font-weight:500;margin:0 0 0.4rem}
.cocktail-card p{color:rgba(255,255,255,0.55);font-size:0.8rem;line-height:1.5;margin:0}
.cocktail-card .c-type{font-size:0.7rem;color:var(--sage);text-transform:uppercase;letter-spacing:1px;margin-bottom:0.4rem}
.activites-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:2rem;margin-top:2.5rem}
.act-card{background:var(--forest2);border-radius:16px;overflow:hidden;border:1px solid rgba(76,175,111,0.15)}
.act-card-top{padding:2rem;background:linear-gradient(135deg,var(--forest),var(--forest2))}
.act-card-top .act-icon{font-size:2.5rem;margin-bottom:0.8rem}
.act-card-top h3{color:#fff;font-family:'Cormorant Garamond',serif;font-size:1.4rem;font-weight:300;margin:0 0 0.3rem}
.act-card-top .act-level{font-size:0.75rem;color:var(--sage);letter-spacing:1px}
.act-card-body{padding:1.5rem 2rem}
.act-card-body p{color:rgba(255,255,255,0.6);font-size:0.85rem;line-height:1.6;margin:0 0 1rem}
.act-tags{display:flex;flex-wrap:wrap;gap:0.5rem}
.act-tag{background:rgba(76,175,111,0.12);color:var(--sage);font-size:0.72rem;padding:3px 10px;border-radius:20px}
.section-intro{max-width:700px;margin:0 auto 1rem;text-align:center;color:rgba(255,255,255,0.65);line-height:1.7}
.section-intro.dark{color:var(--text)}


/* ══ IMAGES & GALERIES V3 ══ */
.img-hero-bg{position:absolute;inset:0;background-size:cover;background-position:center;z-index:0}
.img-hero-bg::after{content:'';position:absolute;inset:0;background:linear-gradient(160deg,rgba(15,31,23,0.80) 0%,rgba(26,72,42,0.68) 50%,rgba(13,42,30,0.86) 100%)}
.hero-content,.hero-stats,.hero-overlay{position:relative;z-index:2}
.gallery-hero{display:grid;grid-template-columns:1.6fr 1fr;grid-template-rows:300px 200px;gap:10px;margin-top:2.5rem}
.gallery-hero .g-main{grid-row:1/3;border-radius:14px;overflow:hidden}
.gallery-hero .g-sm{border-radius:10px;overflow:hidden}
.gallery-hero img,.g-sm img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .4s}
.gallery-hero img:hover{transform:scale(1.03)}
.mosaic{display:grid;grid-template-columns:1.4fr 1fr 1fr;grid-template-rows:auto;gap:10px;margin:2rem 0}
.mosaic-2row{grid-template-rows:240px 180px}
.mosaic .m-big{grid-column:1;grid-row:1/3;border-radius:14px;overflow:hidden}
.mosaic .m-sm{border-radius:10px;overflow:hidden}
.mosaic img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .4s}
.mosaic img:hover{transform:scale(1.04)}
.photo-split{display:grid;grid-template-columns:1fr 1fr;gap:3.5rem;align-items:center;margin-top:2rem}
.photo-split img{width:100%;border-radius:14px;display:block;box-shadow:0 8px 32px rgba(0,0,0,0.12)}
.flag-sm{width:28px;height:19px;object-fit:cover;border-radius:3px;vertical-align:middle;margin-right:6px}
.carte-img{width:100%;border-radius:14px;box-shadow:0 8px 32px rgba(0,0,0,0.15)}
.card-img-top{width:100%;height:180px;object-fit:cover;display:block}
.card-img-top-tall{width:100%;height:220px;object-fit:cover;display:block}
.img-duo{display:grid;grid-template-columns:1fr 1fr;gap:8px;height:220px;margin-bottom:1.5rem}
.img-duo div{border-radius:10px;overflow:hidden}
.img-duo img{width:100%;height:100%;object-fit:cover}
.photo-badge{display:inline-block;background:rgba(15,31,23,0.88);color:#fff;padding:.4rem 1rem;border-radius:20px;font-size:.72rem;font-weight:500;border:1px solid rgba(76,175,111,.4);margin-top:.75rem}
@media(max-width:900px){
  .gallery-hero{grid-template-columns:1fr;grid-template-rows:auto}
  .gallery-hero .g-main{grid-row:auto;height:220px}
  .g-sm{height:180px}
  .mosaic{grid-template-columns:1fr}
  .mosaic .m-big{grid-row:auto;height:220px}
  .mosaic .m-sm{height:160px}
  .photo-split{grid-template-columns:1fr}
  .img-duo{height:160px}
}
</style>
</head>
<body>

